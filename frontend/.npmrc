# ─── Install settings ─────────────────────────────────────────────────────────
# Skip optional dependencies by default (playwright, next-pwa, sharp, allbridge).
# Developers who need e2e tests or production image optimisation can override:
#   pnpm install --optional
# or set:
#   optional=true
optional=false

# Use hoisted node_modules layout (avoids deeply nested duplicates).
# Required by some Next.js / PostCSS plugins that do package-level requires.
node-linker=hoisted

# Avoid building native add-ons unless explicitly needed.
ignore-scripts=false
